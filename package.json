{
  "name": "seed-jira",
  "version": "1.1.0",
  "description": "Seed Jira Cloud SSP project with planning data and simulated activity",
  "packageManager": "pnpm@11.5.3",
  "type": "module",
  "scripts": {
    "seed": "node seed-jira-ssp.mjs",
    "api": "node server.mjs",
    "ui": "vite --config ui/vite.config.ts",
    "dev": "concurrently -n api,ui -c blue,green \"pnpm run api\" \"pnpm run ui\"",
    "build:ui": "vite build --config ui/vite.config.ts",
    "preview:ui": "vite preview --config ui/vite.config.ts"
  },
  "keywords": ["jira", "seed", "ssp"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  }
}
